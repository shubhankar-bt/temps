package com.fincore.CommunicationService.recipient;

import com.fincore.CommunicationService.dto.GenericCommunicationEvent;
import com.fincore.CommunicationService.dto.ResolvedRecipient;
import com.fincore.CommunicationService.recipient.provider.RecipientProvider;
import com.fincore.CommunicationService.recipient.provider.RecipientProviderFactory;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Component;

import java.util.ArrayList;
import java.util.LinkedHashMap;
import java.util.List;
import java.util.Map;
import java.util.concurrent.Executors;
import java.util.concurrent.Future;

/**
 * <p>
 * Resolves every type of recipient supplied by the producer.
 * </p>
 *
 * <p>
 * Supported recipient types:
 * <ul>
 * <li>User Id</li>
 * <li>Role</li>
 * <li>Email</li>
 * <li>Mobile</li>
 * </ul>
 * </p>
 *
 * <p>
 * Each provider executes independently using Java Virtual Threads,
 * allowing database lookups to execute concurrently instead of sequentially.
 * This significantly improves throughput for large recipient groups.
 * </p>
 *
 * @since 2026-07
 */
@Slf4j
@Component
@RequiredArgsConstructor
public class RecipientResolver {

    private final RecipientProviderFactory providerFactory;

    /**
     * Resolve all recipients from the Generic Communication Event.
     *
     * @param recipients Producer supplied recipients.
     * @return Fully resolved Email/Mobile recipients.
     */
    public List<ResolvedRecipient> resolveRecipients(
            GenericCommunicationEvent.Recipients recipients) {

        log.info("Recipient Resolution Started.");

        List<ResolvedRecipient> resolvedRecipients = new ArrayList<>();

        try (var executor = Executors.newVirtualThreadPerTaskExecutor()) {

            List<Future<List<ResolvedRecipient>>> futures = new ArrayList<>();

            if (recipients.getUserIds() != null && !recipients.getUserIds().isEmpty()) {

                RecipientProvider provider = providerFactory.getProvider("USER");

                futures.add(
                        executor.submit(() -> provider.resolve(recipients)));
            }

            if (recipients.getRoles() != null && !recipients.getRoles().isEmpty()) {

                RecipientProvider provider = providerFactory.getProvider("ROLE");

                futures.add(
                        executor.submit(() -> provider.resolve(recipients)));
            }

            if (recipients.getEmails() != null && !recipients.getEmails().isEmpty()) {

                RecipientProvider provider = providerFactory.getProvider("EMAIL");

                futures.add(
                        executor.submit(() -> provider.resolve(recipients)));
            }

            if (recipients.getMobiles() != null && !recipients.getMobiles().isEmpty()) {

                RecipientProvider provider = providerFactory.getProvider("MOBILE");

                futures.add(
                        executor.submit(() -> provider.resolve(recipients)));
            }

            for (Future<List<ResolvedRecipient>> future : futures) {

                resolvedRecipients.addAll(future.get());
            }

        } catch (Exception ex) {

            log.error("Recipient Resolution Failed.", ex);

            throw new RuntimeException("Unable to resolve recipients.", ex);
        }

        List<ResolvedRecipient> uniqueRecipients = removeDuplicates(resolvedRecipients);

        log.info(
                "Recipient Resolution Completed. Total Unique Recipients : {}",
                uniqueRecipients.size());

        return uniqueRecipients;
    }

    /**
     * Removes duplicate recipients.
     *
     * Duplicate detection is based on Email + Mobile.
     */
    private List<ResolvedRecipient> removeDuplicates(
            List<ResolvedRecipient> recipients) {

        Map<String, ResolvedRecipient> uniqueMap = new LinkedHashMap<>();

        for (ResolvedRecipient recipient : recipients) {

            String key = recipient.getEmail() + "|" + recipient.getMobile();

            uniqueMap.putIfAbsent(key, recipient);
        }

        return new ArrayList<>(uniqueMap.values());
    }
}








