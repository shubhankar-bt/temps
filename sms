import java.util.HashMap;
import java.util.List;
import java.util.Map;

/**
 * Factory responsible for providing RecipientProvider
 * implementations.
 *
 * This avoids large if-else blocks inside the
 * RecipientResolver and follows the Factory Pattern.
 *
 * @since 2026-07  
 */
@Slf4j
@Component
@RequiredArgsConstructor
public class RecipientProviderFactory {

    private final List<RecipientProvider> providers;

    private final Map<String, RecipientProvider> providerMap = new HashMap<>();

    @PostConstruct
    public void initializeProviders() {

        log.info("Initializing Recipient Providers.");

        providers.forEach(provider -> {

            providerMap.put(
                    provider.getType(),
                    provider);

            log.info(
                    "Registered Recipient Provider : {}",
                    provider.getType());
        });

        log.info(
                "Recipient Provider Initialization Completed. Total Providers : {}",
                providerMap.size());
    }

    /**
     * Returns the Provider corresponding to
     * the requested recipient type.
     *
     * @param type Recipient Type
     * @return RecipientProvider
     */
    public RecipientProvider getProvider(String type) {

        return providerMap.get(type);
    }
}












