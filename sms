package com.fincore.CommunicationService.repository;

import com.fincore.CommunicationService.model.CommAuditLog;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

@Repository
public interface CommAuditLogRepository extends JpaRepository<CommAuditLog, String> {

    /**
     * O(1) Time Complexity Update.
     * Prevents the overhead of loading the Entity into Hibernate cache just to change the status.
     * @return Number of rows updated.
     */
    @Modifying
    @Transactional
    @Query("UPDATE CommAuditLog c SET c.status = 'SUCCESS', c.updatedAt = CURRENT_TIMESTAMP WHERE c.eventId = :eventId")
    int markAsSuccess(@Param("eventId") String eventId);

    /**
     * O(1) Time Complexity DLQ Failure Update.
     */
    @Modifying
    @Transactional
    @Query("UPDATE CommAuditLog c SET c.status = 'FAILED', c.failureReason = :reason, c.updatedAt = CURRENT_TIMESTAMP WHERE c.eventId = :eventId")
    int markAsFailed(@Param("eventId") String eventId, @Param("reason") String reason);
}

