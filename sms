package com.fincore.CommunicationService.service;

import com.fincore.CommunicationService.config.AsyncAuditConfig;
import com.fincore.CommunicationService.model.CommAuditLog;
import com.fincore.CommunicationService.repository.CommAuditLogRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.dao.DataAccessException;
import org.springframework.scheduling.annotation.Async;
import org.springframework.stereotype.Service;

/**
 * <p>A non-blocking auditing service responsible for storing various logging events
 * in the database.</p>
 *
 * <p>This service utilizes Virtual Threads defined in the {@link AsyncAuditConfig}
 * class to ensure asynchronous processing without blocking the main application flow.</p>
 *
 * @see AsyncAuditConfig
 * @since 2026-06-22
 */
@Slf4j
@Service
@RequiredArgsConstructor
public class CommunicationAuditService {

    private final CommAuditLogRepository auditRepository;

    @Async("virtualThreadAuditExecutor")
    public void logAttempt(String auditId, String eventId, String traceId, String templateId,
                           String channel, String rawRecipient) {
        try {
            CommAuditLog logEntry = CommAuditLog.builder()
                    .auditId(auditId)
                    .eventId(eventId)
                    .traceId(traceId)
                    .producerService("LOGIN_SERVICE") // Hardcoded for OTP; generic will pass dynamically
                    .eventType("LOGIN_OTP")
                    .templateId(templateId)
                    .channel(channel)
                    .maskedRecipient(maskSensitiveData(rawRecipient, channel))
                    .status("PROCESSING")
                    .build();

            auditRepository.save(logEntry);
            log.debug("Async Audit: PROCESSING logged for auditId={}", auditId);

        } catch (DataAccessException e) {
            log.error("Failed to log audit attempt for {}: {}", auditId, e.getMessage());
        }
    }

    @Async("virtualThreadAuditExecutor")
    public void logSuccess(String auditId) {
        try {
            int updated = auditRepository.updateStatusO1(auditId, "SUCCESS");
            if (updated == 0) {
                log.warn("Audit: Tried to mark eventId={} as SUCCESS, but record was missing.", auditId);
            } else {
                log.debug("Audit: Successfully marked eventId={} as SUCCESS", auditId);
            }
        } catch (DataAccessException e) {
            log.error("Database failure while marking audit success for eventId={}", auditId, e);
        }
    }

    @Async("virtualThreadAuditExecutor")
    public void logFailure(String auditId, String failureReason) {
        try {
            // 1. Attempt to update the existing row
            int updatedRows = auditRepository.updateFailureO1(auditId, truncateReason(failureReason));

            // 2. Race Condition Protection:
            // If the message crashed instantly (e.g., malformed JSON), the DLQ might run BEFORE
            // the initial logAttempt finished. If so, we hard-insert the failure.
            if (updatedRows == 0) {
                log.warn("Audit: NOT Handled race condition. Hard-inserted FAILED status for eventId={}", auditId);
//                todo later have to handle
            } else {
                log.debug("Audit: Marked eventId={} as FAILED in DB", auditId);
            }
        } catch (DataAccessException e) {
            log.error("Database failure while writing DLQ audit for eventId={}", auditId, e);
        }
    }

    private String maskSensitiveData(String data, String channel) {
        if (data == null) return "UNKNOWN";
        if ("EMAIL".equalsIgnoreCase(channel) && data.contains("@")) {
            String[] p = data.split("@");
            return (p[0].length() <= 2 ? "**" : p[0].charAt(0) + "***" + p[0].charAt(p[0].length() - 1)) + "@" + p[1];
        } else if ("SMS".equalsIgnoreCase(channel) && data.length() >= 4) {
            return "******" + data.substring(data.length() - 4);
        }
        return "***MASKED***";
    }

    private String truncateReason(String reason) {
        if (reason == null) return "Unknown Failure";
        return reason.length() > 3900 ? reason.substring(0, 3900) + "..." : reason;
    }
}











