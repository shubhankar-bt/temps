    UPDATED_AT TIMESTAMP DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT PK_COMM_AUDIT_LOG PRIMARY KEY (EVENT_ID)
)
PARTITION BY RANGE (CREATED_AT)
INTERVAL(NUMTOYMINTERVAL(1, 'MONTH'))
