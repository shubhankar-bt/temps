package com.fincore.CommunicationService.client;

import org.springframework.stereotype.Component;

import com.fincore.CommunicationService.dto.SmsResponseDTO;
import com.fincore.CommunicationService.model.FincoreSettings;
import com.fincore.CommunicationService.repository.*;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

import javax.net.ssl.*;
import java.io.BufferedReader;
import java.io.IOException;
import java.io.InputStreamReader;
import java.io.OutputStream;
import java.net.HttpURLConnection;
import java.net.URL;
import java.net.URLEncoder;
import java.nio.charset.StandardCharsets;
import java.security.cert.X509Certificate;
import java.util.Base64;

@Component
@RequiredArgsConstructor
@Slf4j
public class SmsGatewayClient {

    private final FincoreSettingsRepository settingsRepository;

    public SmsResponseDTO sendSms(String mobileNumber, String message, String env) {

        FincoreSettings settings = settingsRepository.findByFunctionalityAndEnv("SMS", env)
                .orElseThrow(() -> new RuntimeException("SMS Configuration Missing"));

        try {

            URL url = new URL(settings.getUrl());
            HttpURLConnection connection = (HttpURLConnection) url.openConnection();

            // --- NEW CODE: BYPASS SSL VERIFICATION FOR THIS CONNECTION ---
            if (connection instanceof HttpsURLConnection) {
                HttpsURLConnection httpsConnection = (HttpsURLConnection) connection;
                
                TrustManager[] trustAllCerts = new TrustManager[]{
                    new X509TrustManager() {
                        public X509Certificate[] getAcceptedIssuers() { return null; }
                        public void checkClientTrusted(X509Certificate[] certs, String authType) {}
                        public void checkServerTrusted(X509Certificate[] certs, String authType) {}
                    }
                };
                
                SSLContext sc = SSLContext.getInstance("TLS");
                sc.init(null, trustAllCerts, new java.security.SecureRandom());
                httpsConnection.setSSLSocketFactory(sc.getSocketFactory());
                
                // Allow all hostnames
                httpsConnection.setHostnameVerifier((hostname, session) -> true);
            }
            // -------------------------------------------------------------

            connection.setRequestMethod("POST");
            connection.setConnectTimeout(10000);
            connection.setReadTimeout(10000);

            if (settings.getUsername() != null && settings.getPassword() != null) {
                String auth = settings.getUsername() + ":" + settings.getPassword();
                String encoded = Base64.getEncoder().encodeToString(auth.getBytes());
                connection.setRequestProperty("Authorization", "Basic " + encoded);
            }

            connection.setRequestProperty("Content-Type", "application/x-www-form-urlencoded");

            String payload = "content_type=text" + "&sender_id=" + settings.getSenderId() + "&mobile=0" + mobileNumber + "&message=" + URLEncoder.encode(message, StandardCharsets.UTF_8) + "&intflag=0" + "&charging=0";

            connection.setDoOutput(true);

            try (OutputStream os = connection.getOutputStream()) {
                os.write(payload.getBytes(StandardCharsets.UTF_8));
            }

            int responseCode = connection.getResponseCode();
            String response = readResponse(connection);

            return SmsResponseDTO.builder()
                    .success(responseCode == 200 && response.contains("MESSAGE_SUBMIT_SUCCESS"))
                    .message("SMS Processed")
                    .providerResponse(response)
                    .build();

        } catch (Exception ex) {
            log.error("SMS Sending Failed", ex);
            return SmsResponseDTO.builder().success(false).message(ex.getMessage()).build();
        }
    }

    private String readResponse(HttpURLConnection connection) throws IOException {
        StringBuilder response = new StringBuilder();
        try (BufferedReader reader = new BufferedReader(new InputStreamReader(connection.getInputStream()))) {
            String line;
            while ((line = reader.readLine()) != null) {
                response.append(line);
            }
        }
        return response.toString();
    }
}
