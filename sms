package com.fincore.CommunicationService.repository;

import com.fincore.CommunicationService.model.CommAuditLog;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Modifying;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;
import org.springframework.transaction.annotation.Transactional;

@Repository
public interface CommAuditLogRepository extends JpaRepository<CommAuditLog, String> {

    /**
     * O(1) Time Complexity Status Update.
     * Bypasses the Hibernate Persistence Context (L1 cache) entirely for maximum speed.
     * Prevents N+1 SELECT queries prior to UPDATE.
     */
    @Modifying
    @Transactional
    @Query("UPDATE CommAuditLog a SET a.status = :status, a.updatedAt = CURRENT_TIMESTAMP WHERE a.auditId = :auditId")
    int updateStatusO1(@Param("auditId") String auditId, @Param("status") String status);

    /**
     * O(1) Time Complexity Failure Update.
     */
    @Modifying
    @Transactional
    @Query("UPDATE CommAuditLog a SET a.status = 'FAILED', a.failureReason = :reason, a.updatedAt = CURRENT_TIMESTAMP WHERE a.auditId = :auditId")
    int updateFailureO1(@Param("auditId") String auditId, @Param("reason") String reason);
}











package com.fincore.CommunicationService.service;

import com.fincore.CommunicationService.model.CommAuditLog;
import com.fincore.CommunicationService.repository.CommAuditLogRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.dao.DataAccessException;
import org.springframework.scheduling.annotation.Async;
import org.springframework.stereotype.Service;

/**
 * Enterprise Auditing Engine running on Java 21 Virtual Threads.
 */
@Slf4j
@Service
@RequiredArgsConstructor
public class CommunicationAuditService {

    private final CommAuditLogRepository auditRepository;

    @Async("virtualThreadAuditExecutor")
    public void logAttempt(String auditId, String eventId, String traceId, String templateId, 
                           String channel, String rawRecipient) {
        try {
            CommAuditLog logEntry = CommAuditLog.builder()
                    .auditId(auditId)
                    .eventId(eventId)
                    .traceId(traceId)
                    .producerService("LOGIN_SERVICE") // Hardcoded for OTP; generic will pass dynamically
                    .eventType("LOGIN_OTP")
                    .templateId(templateId)
                    .channel(channel)
                    .maskedRecipient(maskSensitiveData(rawRecipient, channel))
                    .status("PROCESSING")
                    .build();

            auditRepository.save(logEntry);
            log.debug("Async Audit: PROCESSING logged for auditId={}", auditId);
            
        } catch (DataAccessException e) {
            // Swallow exception so DB blips don't crash the Kafka thread
            log.error("Failed to log audit attempt for {}: {}", auditId, e.getMessage());
        }
    }

    @Async("virtualThreadAuditExecutor")
    public void logSuccess(String auditId) {
        try {
            int updated = auditRepository.updateStatusO1(auditId, "SUCCESS");
            if (updated == 0) log.warn("Audit log missing for SUCCESS update: {}", auditId);
        } catch (DataAccessException e) {
            log.error("Failed to mark audit success for {}: {}", auditId, e.getMessage());
        }
    }

    @Async("virtualThreadAuditExecutor")
    public void logFailure(String auditId, String reason) {
        try {
            String safeReason = reason != null && reason.length() > 3900 ? reason.substring(0, 3900) : reason;
            int updated = auditRepository.updateFailureO1(auditId, safeReason);
            
            if (updated == 0) {
                log.warn("Audit race condition for {}. Log attempt was missing, forcing failure insert.", auditId);
                // Implementation note: You can do a fallback save() here if needed.
            }
        } catch (DataAccessException e) {
            log.error("Failed to mark audit failure for {}: {}", auditId, e.getMessage());
        }
    }

    private String maskSensitiveData(String data, String channel) {
        if (data == null) return "UNKNOWN";
        if ("EMAIL".equalsIgnoreCase(channel) && data.contains("@")) {
            String[] p = data.split("@");
            return (p[0].length() <= 2 ? "**" : p[0].charAt(0) + "***" + p[0].charAt(p[0].length() - 1)) + "@" + p[1];
        } else if ("SMS".equalsIgnoreCase(channel) && data.length() >= 4) {
            return "******" + data.substring(data.length() - 4);
        }
        return "***MASKED***";
    }
}

















