import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.cache.annotation.CacheEvict;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;
import java.io.StringReader;
import java.io.StringWriter;
import java.util.Map;

/**
 * High-Speed Template Rendering Engine.
 * * ARCHITECTURE FLOW:
 * 1. Consumer requests compiled template.
 * 2. @Cacheable intercepts: If exists in RAM, returns instantly (< 0.1ms).
 * 3. If missing/expired (12h TTL), method executes: Fetches CLOB from Oracle.
 * 4. FreeMarker securely binds dynamic variables (e.g., ${otpPlaintext}).
 * 5. Compiled String is cached and returned to Consumer.
 */
@Slf4j
@Service
@RequiredArgsConstructor
public class TemplateEngineService {

     private final TemplateRepository templateRepository;
     private final Configuration freeMarkerConfig; // Spring Boot auto-configures this if spring-boot-starter-freemarker is in pom.xml

    /**
     * Fetches the template CLOB and compiles it with the dynamic variables.
     * Caches the raw string to prevent Database OOM and connection exhaustion.
     * The cache key is a composite of Code + Channel + Language (e.g., 'AUTH_LOGIN_OTP_V1:SMS:EN').
     */
    @Cacheable(value = "templates", key = "#templateCode + ':' + #channel + ':' + #language", unless = "#result == null")
    public String compileTemplate(String templateCode, String channel, String language, Map<String, Object> templateData) {

        log.info("L1 CACHE MISS: Fetching Template {} for {} from Oracle DB.", templateCode, channel);

        // 1. Database Lookup
        CommTemplateMaster tmpl = templateRepository.findById(new TemplateId(templateCode, channel, language))
                .orElseThrow(() -> new TemplateNotFoundException("Template not found in Oracle: " + templateCode));

        if (!"Y".equals(tmpl.getIsActive())) {
            throw new TemplateNotFoundException("Template is disabled: " + templateCode);
        }
        String rawClobContent = tmpl.getBodyContent();

        // MOCK CLOB for compilation
//        String rawClobContent = "${otpPlaintext} is the OTP to login to your Fincore application account at SBI. This OTP is valid for ${expiryMins} minutes. Please do not share this OTP with anyone.";

        // --- 2. Secure FreeMarker Compilation ---
        return executeFreeMarkerCompilation(templateCode, rawClobContent, templateData);
    }

    /**
     * Translates Checked Exceptions (IOException, TemplateException) into our
     * Unchecked Custom Exception (TemplateProcessingException).
     * This ensures the Spring Kafka router cleanly sends the message to the DLQ instead of looping infinitely.
     */
    private String executeFreeMarkerCompilation(String templateCode, String rawContent, Map<String, Object> data) {
        try (StringWriter writer = new StringWriter()) {
            // Treat the raw string from DB as a dynamic FreeMarker template
            Template template = new Template(templateCode, new StringReader(rawContent), freeMarkerConfig);

            // Process the template safely
            template.process(data, writer);

            return writer.toString();
        } catch (Exception e) {
            log.error("Fatal error compiling template {}. Missing variables or malformed HTML.", templateCode, e);
            throw new TemplateProcessingException("Failed to bind dynamic variables to template: " + templateCode, e);
        }
    }

    @Cacheable(value = "template_subjects", key = "#templateCode + ':' + #channel + ':' + #language")
    public String getTemplateSubject(String templateCode, String channel, String language) {
        // 1. Database Lookup
        CommTemplateMaster tmpl = templateRepository.findById(new TemplateId(templateCode, channel, language))
                .orElseThrow(() -> new TemplateNotFoundException("Template not found in Oracle: " + templateCode));
        
        // Fetch subject logic...
        return "Fincore Login OTP";
    }

    /**
     * The "Emergency Flush" endpoint.
     * Trigger this via a secured REST API if a manager requires an instant template update
     * without waiting for the 12-hour TTL to expire.
     */
    @CacheEvict(value = {"templates", "template_subjects"}, allEntries = true)
    public void flushTemplateCache() {
        log.warn("ADMIN ACTION: All communication templates evicted from L1/L2 Cache.");
    }

