package com.fincore.CommunicationService.consumer;

import com.fasterxml.jackson.core.JsonProcessingException;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.CommunicationService.dto.GenericCommunicationEvent;
import com.fincore.CommunicationService.exception.CommunicationExceptions.InvalidPayloadException;
import com.fincore.CommunicationService.exception.CommunicationExceptions.VendorDeliveryException;
import com.fincore.CommunicationService.orchestrator.CommunicationOrchestrator;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.kafka.annotation.DltHandler;
import org.springframework.kafka.annotation.EnableKafka;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.kafka.annotation.RetryableTopic;
import org.springframework.kafka.retrytopic.TopicSuffixingStrategy;
import org.springframework.kafka.support.Acknowledgment;
import org.springframework.kafka.support.KafkaHeaders;
import org.springframework.messaging.handler.annotation.Header;
import org.springframework.messaging.handler.annotation.Payload;
import org.springframework.retry.annotation.Backoff;
import org.springframework.stereotype.Component;

/**
 * <p>
 * Non-blocking Kafka Consumer responsible for processing all Generic
 * Communication Events.
 * </p>
 *
 * <p>
 * This consumer handles only the Kafka infrastructure concerns.
 * Business logic is delegated to {@link CommunicationOrchestrator}.
 * </p>
 *
 * <p>
 * Responsibilities:
 * </p>
 * <ol>
 * <li>Consume Generic Communication Event.</li>
 * <li>Deserialize incoming JSON.</li>
 * <li>Validate mandatory fields.</li>
 * <li>Delegate processing to CommunicationOrchestrator.</li>
 * <li>Manually acknowledge Kafka offset.</li>
 * </ol>
 *
 * <p>
 * Retry Architecture:
 * </p>
 * <ul>
 * <li>4 Attempts (1 Initial + 3 Retries).</li>
 * <li>Exponential Backoff (2s → 4s → 8s).</li>
 * <li>Vendor failures are retried.</li>
 * <li>Invalid payloads are sent directly to DLQ.</li>
 * </ul>
 *
 * <p>
 * This consumer intentionally contains no recipient resolution,
 * attachment handling, template processing or vendor specific logic.
 * Those responsibilities belong to the CommunicationOrchestrator.
 * </p>
 *
 * @since 2026-07
 */
@Slf4j
@Component
@EnableKafka
@RequiredArgsConstructor
public class GenericCommunicationConsumer {

    private final ObjectMapper mapper;

    private final CommunicationOrchestrator communicationOrchestrator;

    /**
     * <p>
     * Consumes Generic Communication Events from Kafka.
     * </p>
     *
     * <p>
     * Processing Flow:
     * </p>
     *
     * <pre>
     * Kafka
     *   │
     * Deserialize JSON
     *   │
     * Validate Event
     *   │
     * Communication Orchestrator
     *   │
     * Manual ACK
     * </pre>
     *
     * @param message        Raw Kafka Message
     * @param acknowledgment Kafka Acknowledgment
     * @throws InvalidPayloadException if the message structure is invalid (triggers
     *                                 DLQ).
     * @throws VendorDeliveryException if the external vendor API fails (triggers
     *                                 retry).
     * @throws JsonProcessingException if JSON cannot be parsed.
     */
    @RetryableTopic(attempts = "4", backoff = @Backoff(delay = 2000, multiplier = 2.0), topicSuffixingStrategy = TopicSuffixingStrategy.SUFFIX_WITH_INDEX_VALUE, dltTopicSuffix = "-dlq", exclude = {InvalidPayloadException.class})
    @KafkaListener(topics = "fincore.communication.generic", groupId = "communication-generic-group-v1", containerFactory = "genericCommunicationContainerFactory")
    public void consumeGenericCommunication(@Payload String message, Acknowledgment acknowledgment) throws JsonProcessingException {

        log.info("Received Generic Communication Event : {}", message);

        String eventId = "UNKNOWN";

        try {

            /*
             * ---------------------------------------------------------
             * STEP-1
             * Deserialize Kafka Payload
             * ---------------------------------------------------------
             */
            GenericCommunicationEvent event;

            try {

                event = mapper.readValue(message, GenericCommunicationEvent.class);

                eventId = event.getEventId();

            } catch (Exception ex) {

                throw new InvalidPayloadException("Malformed Generic Communication Event : " + ex.getMessage());
            }

            /*
             * ---------------------------------------------------------
             * STEP-2
             * Validate Mandatory Fields
             * ---------------------------------------------------------
             */
            validateEvent(event);

            log.info("Validated Generic Communication Event : {}", event.getEventId());

            /*
             * ---------------------------------------------------------
             * STEP-3
             * Delegate complete processing to Orchestrator.
             * ---------------------------------------------------------
             */
            communicationOrchestrator.process(event);

            /*
             * ---------------------------------------------------------
             * STEP-4
             * Acknowledge Kafka Offset only after
             * successful completion.
             * ---------------------------------------------------------
             */
            acknowledgment.acknowledge();

            log.info("Successfully processed Generic Communication Event : {}", event.getEventId());

        } catch (InvalidPayloadException ex) {

            log.error("Invalid Generic Communication Event. EventId={} Reason={}", eventId, ex.getMessage());

            throw ex;
        } catch (Exception ex) {

            log.error("Generic Communication processing failed for EventId={}", eventId, ex);

            /*
             * Throwing VendorDeliveryException triggers
             * Spring Kafka Retry mechanism.
             */
            throw new VendorDeliveryException("Generic Communication Processing Failed", ex);
        }
    }

    /**
     * <p>
     * Handles Generic Communication Events that have been routed
     * to the Dead Letter Queue (DLQ).
     * </p>
     *
     * <p>
     * This method is invoked automatically by Spring Kafka when:
     * </p>
     * <ol>
     * <li>All retry attempts are exhausted.</li>
     * <li>A non-retryable exception is thrown.</li>
     * </ol>
     *
     * <p>
     * Current Responsibility:
     * </p>
     * <ul>
     * <li>Log the failure.</li>
     * </ul>
     *
     * <p>
     * Future Responsibility:
     * </p>
     * <ul>
     * <li>Persist Audit Record.</li>
     * <li>Trigger Alerts.</li>
     * <li>Notify Monitoring Systems.</li>
     * </ul>
     *
     * @param message          Original Kafka Message
     * @param originalTopic    Original Kafka Topic
     * @param exceptionMessage Exception responsible for DLQ
     */
    @DltHandler
    public void handleGenericCommunicationDlt(String message, @Header(KafkaHeaders.ORIGINAL_TOPIC) String originalTopic, @Header(KafkaHeaders.EXCEPTION_MESSAGE) String exceptionMessage) {

        log.error("=====================================================");
        log.error("DLQ ALERT : Generic Communication Processing Failed");
        log.error("Original Topic : {}", originalTopic);
        log.error("Failure Reason : {}", exceptionMessage);
        log.error("Failed Payload : {}", message);
        log.error("=====================================================");

        /*
         * TODO
         * CommunicationAuditService.logFailure(...)
         *
         * Audit implementation will be added
         * once Generic Communication Audit
         * module is completed.
         */
    }

    /**
     * Validates mandatory fields required for Generic Communication.
     *
     * @param event Generic Communication Event
     */
    private void validateEvent(GenericCommunicationEvent event) {

        if (event == null) {
            throw new InvalidPayloadException("Generic Communication Event is null.");
        }

        if (event.getEventId() == null || event.getEventId().isBlank()) {

            throw new InvalidPayloadException("Missing Event Id.");
        }

        if (event.getTemplateId() == null || event.getTemplateId().isBlank()) {

            throw new InvalidPayloadException("Missing Template Id.");
        }

        if (event.getChannels() == null || event.getChannels().isEmpty()) {

            throw new InvalidPayloadException("No Communication Channel supplied.");
        }

        if (event.getRecipients() == null) {

            throw new InvalidPayloadException("Recipients object is missing.");
        }

        /*
         * At least one recipient must be present.
         */
        GenericCommunicationEvent.Recipients recipients = event.getRecipients();

        boolean recipientExists = (recipients.getUserIds() != null && !recipients.getUserIds().isEmpty()) || (recipients.getRoles() != null && !recipients.getRoles().isEmpty()) || (recipients.getEmails() != null && !recipients.getEmails().isEmpty()) || (recipients.getMobiles() != null && !recipients.getMobiles().isEmpty());

        if (!recipientExists) {

            throw new InvalidPayloadException("No Recipient supplied.");
        }

        if (event.getPayload() == null) {

            throw new InvalidPayloadException("Payload is missing.");
        }
    }
}




















package com.fincore.CommunicationService.cache;

import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;

import com.fincore.CommunicationService.model.FincoreSettings;
import com.fincore.CommunicationService.repository.FincoreSettingsRepository;

import lombok.RequiredArgsConstructor;

@Service
@RequiredArgsConstructor
public class ExternalApiConfigProvider {

	private final FincoreSettingsRepository repository;

	@Cacheable(value = "externalApiConfigs", key = "#functionality + '_' + #environment")
	public FincoreSettings getConfig(String functionality, String environment) {
