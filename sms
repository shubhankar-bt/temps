package com.fincore.CommunicationService.config;

import lombok.extern.slf4j.Slf4j;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.scheduling.annotation.EnableAsync;

import java.util.concurrent.Executor;
import java.util.concurrent.Executors;

/**
 * <p>Configures asynchronous execution using Java 21 Virtual Threads.</p>
 * <p>Virtual threads are lightweight, meaning we can spawn millions of them without 
 * exhausting OS memory or hitting ThreadPool bottlenecks during DB I/O waits.</p>
 */
@Slf4j
@Configuration
@EnableAsync
public class AsyncAuditConfig {

    @Bean(name = "virtualThreadAuditExecutor")
    public Executor virtualThreadAuditExecutor() {
        log.info("Initializing Java 21 Virtual Thread Executor for Audit Engine...");
        // This is a Java 21 feature. It creates a new virtual thread for every single async task.
        return Executors.newVirtualThreadPerTaskExecutor();
    }
}















