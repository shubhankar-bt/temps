package com.fincore.CommunicationService.recipient.provider;

import com.fincore.CommunicationService.dto.GenericCommunicationEvent;
import com.fincore.CommunicationService.dto.ResolvedRecipient;
import com.fincore.CommunicationService.model.Role;
import com.fincore.CommunicationService.model.User;
import com.fincore.CommunicationService.model.UserRole;
import com.fincore.CommunicationService.repository.RoleRepository;
import com.fincore.CommunicationService.repository.UserRepository;
import com.fincore.CommunicationService.repository.UserRoleRepository;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Component;

import java.util.Collections;
import java.util.List;

/**
 * Resolves Role based recipients into Email and Mobile details.
 *
 * Flow:
 *
 * Roles
 * ↓
 * RoleRepository
 * ↓
 * Role Ids
 * ↓
 * UserRoleRepository
 * ↓
 * User Ids
 * ↓
 * UserRepository
 * ↓
 * Email + Mobile
 *
 * Supports:
 * - Single Role
 * - Multiple Roles
 * - ALL Roles
 *
 * @since 2026-07
 */
@Slf4j
@Component
@RequiredArgsConstructor
public class RoleRecipientProvider implements RecipientProvider {

    private static final String ACTIVE = "ACTIVE";

    private final RoleRepository roleRepository;

    private final UserRoleRepository userRoleRepository;

    private final UserRepository userRepository;

    @Override
    @Cacheable(value = "roles", key = "#recipients.roles")
    public List<ResolvedRecipient> resolve(
            GenericCommunicationEvent.Recipients recipients) {

        if (recipients.getRoles() == null
                || recipients.getRoles().isEmpty()) {

            return Collections.emptyList();
        }

        log.info("Resolving recipients for Roles : {}", recipients.getRoles());

        List<Role> roles;

        if (recipients.getRoles().contains("ALL")) {

            log.info("Received ALL Roles. Fetching all active roles.");

            roles = roleRepository.findByRoleStatus(ACTIVE);

        } else {

            roles = roleRepository.findByRoleNameIn(
                    recipients.getRoles());
        }

        if (roles.isEmpty()) {

            log.warn("No Roles found.");

            return Collections.emptyList();
        }

        List<Long> roleIds = roles.stream()
                .map(Role::getRoleId)
                .toList();

        List<UserRole> mappings = userRoleRepository.findByRoleIdIn(roleIds);

        if (mappings.isEmpty()) {

            log.warn("No User mappings found for Roles.");

            return Collections.emptyList();
        }

        List<String> userIds = mappings.stream()
                .map(UserRole::getUserId)
                .distinct()
                .toList();

        List<User> users = userRepository.findByUserIdIn(userIds);

        log.info("Resolved {} User(s) from Role(s).", users.size());

        return users.stream()
                .map(user -> ResolvedRecipient.builder()
                        .userId(user.getUserId())
                        .email(user.getEmail())
                        .mobile(user.getPhoneNumber())
                        .build())
                .toList();
    }

    @Override
    public String getType() {
        return "ROLE";
    }
}










