    TX_ID VARCHAR2(100) NOT NULL,
    TEMPLATE_ID VARCHAR2(50) NOT NULL,
    CHANNELS VARCHAR2(50) NOT NULL,
    MASKED_RECIPIENTS VARCHAR2(255) NOT NULL,
    STATUS VARCHAR2(20) NOT NULL, -- Values: 'PROCESSING', 'SUCCESS', 'FAILED'
