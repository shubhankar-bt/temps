-- TABLE: COMM_AUDIT_LOG
-- PURPOSE: Unified, denormalized audit trail for all outbound communications.
-- OPTIMIZATION: Interval partitioned by month for automatic data lifecycle management.
-- ==============================================================================
CREATE TABLE COMM_AUDIT_LOG (
    AUDIT_ID VARCHAR2(100) NOT NULL, -- Format: {eventId}_{channel}_{recipientHash}
    EVENT_ID VARCHAR2(100) NOT NULL,
    TRACE_ID VARCHAR2(100),
    CORRELATION_ID VARCHAR2(100),
    PRODUCER_SERVICE VARCHAR2(50),
    EVENT_TYPE VARCHAR2(50),
    TEMPLATE_ID VARCHAR2(50),
    CHANNEL VARCHAR2(20) NOT NULL, -- EMAIL, SMS
    MASKED_RECIPIENT VARCHAR2(255) NOT NULL,
    STATUS VARCHAR2(20) DEFAULT 'PROCESSING' NOT NULL, -- PROCESSING, SUCCESS, FAILED
    FAILURE_REASON CLOB,
    CREATED_AT TIMESTAMP DEFAULT SYSTIMESTAMP NOT NULL,
    UPDATED_AT TIMESTAMP DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT PK_COMM_AUDIT_LOG PRIMARY KEY (AUDIT_ID)
)
PARTITION BY RANGE (CREATED_AT)
INTERVAL(NUMTOYMINTERVAL(1, 'MONTH'))
(
    PARTITION p_initial VALUES LESS THAN (TO_DATE('2024-01-01', 'YYYY-MM-DD'))
);

