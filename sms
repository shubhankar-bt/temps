package com.fincore.CommunicationService.exception;

/**
 * Exception Taxonomy for the Communication Service.
 */
public class CommunicationExceptions {

    /**
     * Deterministic Error: Do NOT Retry. Route to DLQ instantly.
     */
    public static class DecryptionFailureException extends RuntimeException {
        public DecryptionFailureException(String message, Throwable cause) { super(message, cause); }
    }

    /**
     * Deterministic Error: Do NOT Retry. Missing DB configuration.
     */
    public static class TemplateNotFoundException extends RuntimeException {
        public TemplateNotFoundException(String message) { super(message); }
    }

    /**
     * Transient Error: Vendor Timeout/502. DO Retry with Exponential Backoff.
     */
    public static class VendorDeliveryException extends RuntimeException {
        public VendorDeliveryException(String message, Throwable cause) { super(message, cause); }
    }

    /**
     * Data Error: Invalid Payload structure. Do NOT Retry.
     */
    public static class InvalidPayloadException extends RuntimeException {
        public InvalidPayloadException(String message) { super(message); }
    }

    /**
     * Deterministic Error: Thrown if FreeMarker fails to compile (e.g., missing variable).
     * DO NOT RETRY. Route to DLQ instantly, as retrying a broken template will always fail.
     */
    public static class TemplateProcessingException extends RuntimeException {
        public TemplateProcessingException(String message, Throwable cause) { super(message, cause); }
    }
}








