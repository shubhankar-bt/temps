    private String formatDimension(DimensionConfig config) {
        if (config.isExpression()) {
            // For complex SQL (e.g., CASE WHEN), wrap in parentheses
            return "(" + config.physicalSql() + ")";
        } else {
            String physicalCol = config.physicalSql();
            
            // BACKEND RESILIENCE: Prevent "Double-Double Quote" syntax errors
            // If the database mapping already includes quotes, use it as-is.
            if (physicalCol.startsWith("\"") && physicalCol.endsWith("\"")) {
                return physicalCol;
            }
            
            // Otherwise, wrap it securely
            return "\"" + physicalCol + "\"";
        }
    }


