import com.fincore.analyticsservice.model.DrViewDimension;
import com.fincore.analyticsservice.repository.DrReportRepository;
import com.fincore.analyticsservice.repository.RbParsedTemplateRepository;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.security.access.AccessDeniedException;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;


import java.util.*;

@Service
public class ReportConfigService {

    private static final Integer ROLE_ADMIN = 10;
    private static final Logger log = LoggerFactory.getLogger(ReportConfigService.class);
    private final DrReportRepository reportRepository;
    private final RbParsedTemplateRepository templateRepository; // <-- NEW


    public ReportConfigService(DrReportRepository reportRepository, RbParsedTemplateRepository templateRepository) {
        this.reportRepository = reportRepository;
        this.templateRepository = templateRepository;
    }

    /**
     * Fetches UI metadata.
     * Caches the response by User Roles to ensure users only see their permitted views.
     */
    @Transactional(readOnly = true)
    @Cacheable(value = "uiReportConfig", key = "#roleId")
    public List<ReportConfigResponse> getPermittedConfigurations(Integer roleId) {
        log.info("Fetching Oracle UI configurations for roles: {}", roleId);

        List<DrReport> allActiveReports = reportRepository.findAllActiveReportsWithViews();
        List<ReportConfigResponse> permittedReports = new ArrayList<>();

        for (DrReport report : allActiveReports) {
            List<ViewConfig> permittedViews = processViews(report.getViews(), roleId);
           
            // Only return the report if the user has access to at least one view inside it
            if (!permittedViews.isEmpty()) {
                permittedReports.add(new ReportConfigResponse(
                        report.getReportCode(),
                        report.getDisplayName(),
                        permittedViews
                ));
            }
        }

        if (permittedReports.isEmpty()) {
            log.warn("User with role {} requested config but has zero report permissions.", roleId);
            throw new AccessDeniedException("You do not have permission to view any reports.");
        }

        return permittedReports;
    }

    private List<ViewConfig> processViews(Set<DrReportView> views, Integer roleId) {

        List<ViewConfig> permittedViews = new ArrayList<>();

        for (DrReportView view : views) {
            if (hasAccess(roleId, view.getRequiredRoleIds())) {

                // 1. Map Hierarchy (Must be strictly ordered by drillLevel)
                List<String> logicalHierarchy = view.getDimensions().stream()
                        .sorted(Comparator.comparing(DrViewDimension::getDrillLevel))
                        .map(DrViewDimension::getLogicalName)
                        .toList();

                // 2. Map Metrics
                List<MetricConfig> logicalMetrics = view.getMetrics().stream()
                        .map(m -> new MetricConfig(m.getLogicalName(), m.getDisplayName()))//Cannot resolve method 'getDisplayName' in 'DrViewMetric'
                        .toList();

                permittedViews.add(new ViewConfig(
                        view.getViewCode(),
                        // Assuming you have a displayName in DrReportView, otherwise use viewCode
                        view.getViewCode(),
                        logicalHierarchy,
                        logicalMetrics
                ));
            }
        }
        return permittedViews;
    }

    private boolean hasAccess(Integer roleId, String requiredRoleIds) {

        // admin has access of everything
        if (ROLE_ADMIN.equals(roleId)) {
            return true;
        }

        // If no role is required, it's public. Otherwise, check user roles.
        // Allow access to all the roles
        if (requiredRoleIds == null || requiredRoleIds.isBlank() || "NULL".equalsIgnoreCase(requiredRoleIds.trim())) {
            return true;
        }

        List<String> allowedRoles = Arrays.asList(requiredRoleIds.split(","));

        // return true if allowed roles contains the role id
        return allowedRoles.contains(String.valueOf(roleId));
    }

    public List<HeadSearchResponse> searchHeads(String reportName, String searchText) {
        return templateRepository.searchHeads(reportName, searchText.trim());
    }
}






package com.fincore.analyticsservice.service;

import com.fincore.analyticsservice.dto.DimensionConfig;
import com.fincore.analyticsservice.dto.ViewMetadataContext;
import com.fincore.analyticsservice.model.DrReportView;
import com.fincore.analyticsservice.model.DrViewDimension;
import com.fincore.analyticsservice.model.DrViewMetric;
import com.fincore.analyticsservice.repository.DrReportViewRepository;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

@Service
public class OracleMetadataProviderImpl implements ReportMetadataProvider {

    private static final Logger log = LoggerFactory.getLogger(OracleMetadataProviderImpl.class);
    private final DrReportViewRepository viewRepository;

    public OracleMetadataProviderImpl(DrReportViewRepository viewRepository) {
        this.viewRepository = viewRepository;
    }

    @Override
    @Transactional(readOnly = true)
    @Cacheable(value = "viewMetadataContextCache", key = "#viewCode")
    public ViewMetadataContext getViewContext(String viewCode) {
        log.debug("Cache miss. Fetching physical mapping for viewCode: [{}] from Oracle DB", viewCode);

        DrReportView viewEntity = viewRepository.findByViewCodeActive(viewCode)
                .orElseThrow(() -> new IllegalArgumentException("Invalid or inactive viewCode requested: " + viewCode));

        // Hibernate triggers Query #2 here securely inside the transaction boundary
        List<String> orderedHierarchy = viewEntity.getDimensions().stream()
                .map(DrViewDimension::getLogicalName)
                .toList();

        // 2. Build Translation Maps (Logical -> Physical)
        // maps the Logical Name to the new DimensionConfig object
        Map<String, DimensionConfig> dimMap = viewEntity.getDimensions().stream()
                .collect(Collectors.toMap(
                        DrViewDimension::getLogicalName,
                        dim -> new DimensionConfig(dim.getPhysicalColumn(), dim.isExpression())
                ));

        // Hibernate triggers Query #3 here securely inside the transaction boundary
        Map<String, String> metricMap = viewEntity.getMetrics().stream()
                .collect(Collectors.toMap(DrViewMetric::getLogicalName, DrViewMetric::getSqlExpression));

        // 3. Construct and return immutable context
        return new ViewMetadataContext(
                viewEntity.getViewCode(),
                viewEntity.getDatasource().getDruidTableName(),
                viewEntity.getRequiredRoleIds(),
                orderedHierarchy,
                dimMap,
                metricMap
        );
    }
}






package com.fincore.analyticsservice.service;

import com.fincore.analyticsservice.dto.ViewMetadataContext;

/**
 * Enterprise boundary interface for fetching Report Metadata.
 * Allows switching from Oracle to another metadata store in the future without changing business logic.
 */
public interface ReportMetadataProvider {

    /**
     * Fetches the physical mapping context for a given logical view code.
     * @param viewCode The logical identifier from the UI (e.g., 'YSA_BRANCH_VIEW')
     * @return Immutable context containing physical table names and column mappings.
     */
    ViewMetadataContext getViewContext(String viewCode);
}














