package com.fincore.analyticsservice.model;

import jakarta.persistence.*;
import lombok.Getter;
import lombok.Setter;

@Entity
@Table(name = "DR_VIEW_DIMENSION")
@Getter
@Setter
public class DrViewDimension {
    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @ManyToOne(fetch = FetchType.LAZY)
    @JoinColumn(name = "VIEW_ID", nullable = false)
    private DrReportView reportView;

    @Column(name = "LOGICAL_NAME", nullable = false)
    private String logicalName;

    @Column(name = "PHYSICAL_COLUMN", nullable = false)
    private String physicalColumn;

    @Column(name = "IS_EXPRESSION", nullable = false)
    private boolean isExpression;

    // We need this mapped so Java can filter out the hidden level 90+ items!
    @Column(name = "DRILL_LEVEL", nullable = false)
    private Integer drillLevel; 
}










package com.fincore.analyticsservice.service;

import com.fincore.analyticsservice.dto.DimensionConfig;
import com.fincore.analyticsservice.dto.ViewMetadataContext;
import com.fincore.analyticsservice.model.DrReportView;
import com.fincore.analyticsservice.model.DrViewDimension;
import com.fincore.analyticsservice.model.DrViewMetric;
import com.fincore.analyticsservice.repository.DrReportViewRepository;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.Comparator;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

@Service
public class OracleMetadataProviderImpl implements ReportMetadataProvider {

    private static final Logger log = LoggerFactory.getLogger(OracleMetadataProviderImpl.class);
    private final DrReportViewRepository viewRepository;

    public OracleMetadataProviderImpl(DrReportViewRepository viewRepository) {
        this.viewRepository = viewRepository;
    }

    @Override
    @Transactional(readOnly = true)
    @Cacheable(value = "viewMetadataContextCache", key = "#viewCode")
    public ViewMetadataContext getViewContext(String viewCode) {
        log.debug("Cache miss. Loading mappings from Oracle for viewCode: [{}]", viewCode);

        DrReportView viewEntity = viewRepository.findByViewCodeActive(viewCode)
                .orElseThrow(() -> new IllegalArgumentException("Invalid or inactive viewCode: " + viewCode));

        // 🚀 THE FIX: Filter out Level 90+ (Hidden Filters) and sort the remaining columns
        List<String> orderedHierarchy = viewEntity.getDimensions().stream()
                .filter(dim -> dim.getDrillLevel() != null && dim.getDrillLevel() < 90)
                .sorted(Comparator.comparing(DrViewDimension::getDrillLevel))
                .map(DrViewDimension::getLogicalName)
                .toList();

        // Keep ALL dimensions (including 90+) in the map so DruidQueryBuilder can use them for filtering
        Map<String, DimensionConfig> dimMap = viewEntity.getDimensions().stream()
                .collect(Collectors.toMap(
                        DrViewDimension::getLogicalName, 
                        dim -> new DimensionConfig(dim.getPhysicalColumn(), dim.isExpression())
                ));

        Map<String, String> metricMap = viewEntity.getMetrics().stream()
                .collect(Collectors.toMap(DrViewMetric::getLogicalName, DrViewMetric::getSqlExpression));

        return new ViewMetadataContext(
                viewEntity.getViewCode(),
                viewEntity.getDatasource().getDruidTableName(),
                viewEntity.getDatasource().getClusterUrl(),
                viewEntity.getRequiredRoleIds(),
                orderedHierarchy,
                dimMap,
                metricMap
        );
    }
}


















package com.fincore.analyticsservice.service;

import com.fincore.analyticsservice.dto.ReportConfigResponse;
import com.fincore.analyticsservice.dto.ViewConfigDto;
import com.fincore.analyticsservice.dto.MetricConfigDto;
import com.fincore.analyticsservice.model.DrReport;
import com.fincore.analyticsservice.model.DrReportView;
import com.fincore.analyticsservice.model.DrViewDimension;
import com.fincore.analyticsservice.model.DrViewMetric;
import com.fincore.analyticsservice.repository.DrReportRepository;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.Comparator;
import java.util.List;
import java.util.stream.Collectors;
import java.util.Arrays;

@Service
public class ReportConfigService {

    private final DrReportRepository reportRepository;

    public ReportConfigService(DrReportRepository reportRepository) {
        this.reportRepository = reportRepository;
    }

    @Transactional(readOnly = true)
    public List<ReportConfigResponse> getPermittedConfigurations(Integer userRoleId) {
        List<DrReport> allReports = reportRepository.findAllActiveReports();

        return allReports.stream().map(report -> {
            List<ViewConfigDto> permittedViews = report.getViews().stream()
                    .filter(DrReportView::isActive)
                    .filter(view -> isRolePermitted(view.getRequiredRoleIds(), userRoleId))
                    .map(this::mapToViewConfig)
                    .toList();

            if (permittedViews.isEmpty()) return null;

            return new ReportConfigResponse(
                    report.getReportCode(),
                    report.getDisplayName(),
                    permittedViews
            );
        }).filter(java.util.Objects::nonNull).toList();
    }

    private ViewConfigDto mapToViewConfig(DrReportView view) {
        // 🚀 THE FIX: Ensure the UI is only told about Drill Levels < 90!
        List<String> hierarchy = view.getDimensions().stream()
                .filter(dim -> dim.getDrillLevel() != null && dim.getDrillLevel() < 90)
                .sorted(Comparator.comparing(DrViewDimension::getDrillLevel))
                .map(DrViewDimension::getLogicalName)
                .toList();

        List<MetricConfigDto> metrics = view.getMetrics().stream()
                .map(m -> new MetricConfigDto(m.getLogicalName(), m.getDisplayName()))
                .toList();

        return new ViewConfigDto(
                view.getViewCode(),
                view.getDisplayName(),
                hierarchy,
                metrics
        );
    }

    private boolean isRolePermitted(String requiredRolesStr, Integer userRoleId) {
        if (requiredRolesStr == null || requiredRolesStr.trim().isEmpty()) return false;
        return Arrays.stream(requiredRolesStr.split(","))
                .map(String::trim)
                .anyMatch(role -> role.equals(String.valueOf(userRoleId)));
    }
}

















