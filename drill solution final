package com.fincore.analyticsservice.dto;

public record HeadSearchResponse(
    String headCode,
    String headName
) {}




package com.fincore.analyticsservice.repository;

import com.fincore.analyticsservice.dto.HeadSearchResponse;
import jakarta.persistence.*;
import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.data.jpa.repository.Query;
import org.springframework.data.repository.query.Param;
import org.springframework.stereotype.Repository;

import java.util.List;

// 1. The Entity Mapping
@Entity
@Table(name = "RB_PARSED_TEMPLATE")
class RbParsedTemplate {
    // We use a composite of runId + headCode + cgl as a logical ID for JPA
    @Id 
    @Column(name = "HEAD_CODE")
    private String headCode;

    @Column(name = "RUN_ID")
    private String runId;

    @Column(name = "HEAD_DESC")
    private String headDesc;
}

// 2. The Repository Search Engine
@Repository
public interface RbParsedTemplateRepository extends JpaRepository<RbParsedTemplate, String> {

    /**
     * Executes a fast, case-insensitive search across both HEAD_CODE and HEAD_DESC.
     * Returns a distinct list mapped directly to our DTO to avoid memory overhead.
     */
    @Query("""
        SELECT DISTINCT new com.fincore.analyticsservice.dto.HeadSearchResponse(t.headCode, t.headDesc) 
        FROM RbParsedTemplate t 
        WHERE LOWER(t.runId) = LOWER(:reportName) 
          AND (
               LOWER(t.headCode) LIKE LOWER(CONCAT('%', :searchText, '%')) 
               OR LOWER(t.headDesc) LIKE LOWER(CONCAT('%', :searchText, '%'))
          )
        ORDER BY t.headCode ASC
    """)
    List<HeadSearchResponse> searchHeads(
            @Param("reportName") String reportName, 
            @Param("searchText") String searchText
    );
}










