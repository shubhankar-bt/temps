package com.fincore.CommunicationService.consumer;

import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.commonutilities.util.AesEncryptionUtil;
import com.fincore.CommunicationService.dto.KafkaEvent;
import com.fincore.CommunicationService.exception.CommunicationExceptions.*;
import com.fincore.CommunicationService.service.EmailService;
import com.fincore.CommunicationService.service.SmsService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.kafka.annotation.RetryableTopic;
import org.springframework.kafka.retrytopic.TopicSuffixingStrategy;
import org.springframework.kafka.support.Acknowledgment;
import org.springframework.messaging.handler.annotation.Payload;
import org.springframework.retry.annotation.Backoff;
import org.springframework.stereotype.Component;

import javax.crypto.BadPaddingException;
import javax.crypto.IllegalBlockSizeException;
import java.security.GeneralSecurityException;
import java.time.Duration;
import java.util.Map;

@Slf4j
@Component
@RequiredArgsConstructor
public class PriorityOtpConsumer {

    private final ObjectMapper mapper;
    private final AesEncryptionUtil aesUtil;
    private final StringRedisTemplate redisTemplate;
    
    private final SmsService smsService;     
    private final EmailService emailService; 

    @Value("${security.internal.kafka-aes-key}")
    private String internalAesKey;

    @RetryableTopic(
            attempts = "4",
            backoff = @Backoff(delay = 2000, multiplier = 2.0),
            topicSuffixingStrategy = TopicSuffixingStrategy.SUFFIX_WITH_INDEX_VALUE,
            dltTopicSuffix = "-dlq",
            exclude = { DecryptionFailureException.class, InvalidPayloadException.class, TemplateNotFoundException.class }
    )
    @KafkaListener(
            topics = "fincore.auth.otp.priority",
            groupId = "communication-login-otp-group",
            containerFactory = "priorityOtpContainerFactory"
    )
    public void consumeOtpEvent(@Payload KafkaEvent event, Acknowledgment acknowledgment) {

        String txId = event.getTxId();
        log.debug("Received Tier-0 OTP Event for txId={}", txId);

        try {
            if (txId == null || event.getPayload() == null) {
                throw new InvalidPayloadException("Missing txId or encrypted payload");
            }

            // 1. ZERO-TRUST DECRYPTION
            String decryptedJson;
            try {
                decryptedJson = aesUtil.decrypt(event.getPayload(), internalAesKey);
            } catch (BadPaddingException | IllegalBlockSizeException e) {
                log.error("SECURITY ALERT: Decryption failed for txId={}. Data tampered or key mismatch.", txId, e);
                throw new DecryptionFailureException("AES Decryption Failed: Invalid Padding", e);
            } catch (GeneralSecurityException e) {
                throw new DecryptionFailureException("AES Decryption Failed", e);
            }

            // Map decrypted JSON into a generic map to pass to FreeMarker/TemplateService
            Map<String, Object> templateDataMap = mapper.readValue(decryptedJson, new TypeReference<>() {});

            boolean requiresRetry = false;

            // 2. CHANNEL ROUTING & IDEMPOTENCY
            for (String channel : event.getChannels()) {
                String idempotencyKey = "COMM_IDEMP:" + txId + ":" + channel.toUpperCase();

                Boolean alreadyProcessed = redisTemplate.opsForValue().setIfAbsent(idempotencyKey, "PROCESSED", Duration.ofMinutes(15));
                if (Boolean.FALSE.equals(alreadyProcessed)) {
                    log.info("Idempotency hit: Already processed {} for txId={}. Skipping.", channel, txId);
                    continue;
                }

                try {
                    if ("SMS".equalsIgnoreCase(channel)) {
                        smsService.sendSms(event.getEnvironment(), event.getTemplateId(), event.getRecipient().getMobile(), templateDataMap);
                    } else if ("EMAIL".equalsIgnoreCase(channel)) {
                        emailService.sendEmail(event.getEnvironment(), event.getTemplateId(), event.getRecipient().getEmail(), templateDataMap);
                    }
                } catch (Exception e) {
                    redisTemplate.delete(idempotencyKey); // Allow retry on failure
                    log.error("Vendor dispatch failed for txId={} channel={}. Exception: {}", txId, channel, e.getMessage());
                    requiresRetry = true;
                }
            }

            if (requiresRetry) {
                throw new VendorDeliveryException("One or more channels failed to deliver.", null);
            }

            acknowledgment.acknowledge();
            log.info("Successfully processed Tier-0 OTP Event for txId={}", txId);

        } catch (DecryptionFailureException | InvalidPayloadException | TemplateNotFoundException e) {
            log.error("Fatal deterministic error processing txId={}. Routing to DLQ. Reason: {}", txId, e.getMessage());
            throw e;
        } catch (Exception e) {
            log.error("Unexpected error processing Kafka message: {}", e.getMessage(), e);
            throw new InvalidPayloadException("Unexpected message parsing error");
        }
    }
}

