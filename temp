public class CommTemplateMaster {

    @EmbeddedId
    private TemplateId id;

    @Column(name = "SUBJECT", length = 255)
    private String subject;

    @Lob
    @Column(name = "BODY_CONTENT", nullable = false, columnDefinition = "CLOB")
    private String bodyContent;

    @Column(name = "IS_ACTIVE", length = 1, nullable = false)
    private String isActive;

    @Column(name = "CREATED_BY", length = 50, nullable = false)
    private String createdBy;

    @CreationTimestamp
    @Column(name = "CREATED_AT", nullable = false, updatable = false)
    private LocalDateTime createdAt;

    @Column(name = "UPDATED_BY", length = 50)
    private String updatedBy;

    @UpdateTimestamp
    @Column(name = "UPDATED_AT")
    private LocalDateTime updatedAt;

}









package com.fincore.CommunicationService.service;

import com.fincore.CommunicationService.exception.CommunicationExceptions.TemplateNotFoundException;
import com.fincore.CommunicationService.exception.CommunicationExceptions.TemplateProcessingException;
import com.fincore.CommunicationService.model.CommTemplateMaster;
import com.fincore.CommunicationService.model.TemplateId;
import com.fincore.CommunicationService.repository.TemplateRepository;
import freemarker.template.Configuration;
import freemarker.template.Template;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.cache.annotation.CacheEvict;
import org.springframework.cache.annotation.Cacheable;
import org.springframework.context.annotation.Lazy;
import org.springframework.stereotype.Service;

import java.io.StringReader;
import java.io.StringWriter;
import java.util.Map;

/**
 * High-Speed Template Rendering Engine.
 * * ARCHITECTURE FLOW:
 * 1. Consumer requests compiled template.
 * 2. @Cacheable intercepts: If exists in RAM, returns instantly (< 0.1ms).
 * 3. If missing/expired (12h TTL), method executes: Fetches CLOB from Oracle.
 * 4. FreeMarker securely binds dynamic variables (e.g., ${otpPlaintext}).
 * 5. Compiled String is cached and returned to Consumer.
 */
@Slf4j
@Service
@RequiredArgsConstructor
public class TemplateEngineService {

    private final TemplateRepository templateRepository;
    private final Configuration freeMarkerConfig; // Spring Boot auto-configures this if spring-boot-starter-freemarker is in pom.xml

    @Autowired
    @Lazy
    private TemplateEngineService self;

    /**
     * PUBLIC API: Renders the final string.
     * THIS IS NOT CACHED. It processes dynamic variables on every single request
     * to prevent Cross-Pollination data leaks (e.g., User B getting User A's OTP).
     */
    public String renderTemplate(String templateCode, String channel, String language, Map<String, Object> templateData) {
        // 1. Fetch the cached, pre-compiled Template AST Object
        Template compiledTemplate = self.getCompiledTemplate(templateCode, channel, language);

        // 2. Thread-safely merge dynamic data (OTP, Names) into the template
        try (StringWriter writer = new StringWriter()) {
            compiledTemplate.process(templateData, writer);
            return writer.toString();
        } catch (Exception e) {
            log.error("Fatal error binding dynamic variables to template {}.", templateCode, e);
            throw new TemplateProcessingException("Failed to bind dynamic variables to template: " + templateCode, e);
        }
    }

    /**
     * INTERNAL CACHE: Fetches from Oracle DB and compiles the FreeMarker AST.
     * Caching the FreeMarker Template object saves both Database I/O and Parsing CPU.
     * The cache key is a composite of Code + Channel + Language (e.g., 'AUTH_LOGIN_OTP_V1:SMS:EN').
     */
    @Cacheable(value = "templates", key = "#templateCode + ':' + #channel + ':' + #language", unless = "#result == null")
    public Template getCompiledTemplate(String templateCode, String channel, String language) {

        log.info("L1 CACHE MISS: Fetching and Compiling Template {} for {} from Oracle DB.", templateCode, channel);

        // 1. Database Lookup
        CommTemplateMaster tmpl = templateRepository.findById(new TemplateId(templateCode, channel, language))
                .orElseThrow(() -> new TemplateNotFoundException("Template not found in Oracle: " + templateCode));

        log.info("Template received from DB : {}", tmpl);

        if (!"Y".equalsIgnoreCase(tmpl.getIsActive().trim())) {
            throw new TemplateNotFoundException("Template is disabled: " + templateCode);
        }
        String rawClobContent = tmpl.getBodyContent();

        // 2. Compile into Abstract Syntax Tree (AST)
        try {
            return new Template(templateCode, new StringReader(rawClobContent), freeMarkerConfig);
        } catch (Exception e) {
            log.error("Syntax error in FreeMarker template {}.", templateCode, e);
            throw new TemplateProcessingException("Syntax error compiling template: " + templateCode, e);
        }
    }


    @Cacheable(value = "template_subjects", key = "#templateCode + ':' + #channel + ':' + #language")
    public String getTemplateSubject(String templateCode, String channel, String language) {
        // 1. Database Lookup
        CommTemplateMaster tmpl = templateRepository.findById(new TemplateId(templateCode, channel, language))
                .orElseThrow(() -> new TemplateNotFoundException("Template not found in Oracle: " + templateCode));
        return tmpl.getSubject();
    }

    /**
     * The "Emergency Flush" endpoint.
     * Trigger this via a secured REST API if a manager requires an instant template update
     * without waiting for the 12-hour TTL to expire.
     */
    @CacheEvict(value = {"templates", "template_subjects"}, allEntries = true)
    public void flushTemplateCache() {
        log.warn("ADMIN ACTION: All communication templates evicted from L1/L2 Cache.");
    }

}







