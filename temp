package com.fincore.communication.consumer;

import com.fasterxml.jackson.core.type.TypeReference;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.commonutilities.util.AesEncryptionUtil;
import com.fincore.communication.exception.CommunicationExceptions.*;
import com.fincore.communication.service.EmailService; // Junior's Component
import com.fincore.communication.service.SmsService;   // Junior's Component
import com.fincore.communication.service.TemplateEngineService;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.data.redis.core.StringRedisTemplate;
import org.springframework.kafka.annotation.KafkaListener;
import org.springframework.kafka.annotation.RetryableTopic;
import org.springframework.kafka.retrytopic.TopicSuffixingStrategy;
import org.springframework.kafka.support.Acknowledgment;
import org.springframework.kafka.support.KafkaHeaders;
import org.springframework.messaging.handler.annotation.Header;
import org.springframework.messaging.handler.annotation.Payload;
import org.springframework.retry.annotation.Backoff;
import org.springframework.stereotype.Component;

import java.time.Duration;
import java.util.List;
import java.util.Map;

@Slf4j
@Component
@RequiredArgsConstructor
public class PriorityOtpConsumer {

    private final ObjectMapper mapper;
    private final AesEncryptionUtil aesUtil;
    private final StringRedisTemplate redisTemplate;
    
    // Services
    private final TemplateEngineService templateService;
    private final SmsService smsService;     // Built by Juniors
    private final EmailService emailService; // Built by Juniors

    @Value("${security.internal.kafka-aes-key}")
    private String internalAesKey;

    /**
     * KAFKA RETRY ARCHITECTURE:
     * - Attempts: 4 (1 Initial + 3 Retries)
     * - Backoff: 2s, 4s, 8s (Exponential)
     * - Excludes: DecryptionFailure, InvalidPayload, TemplateNotFound (Goes straight to DLQ)
     * - Includes: VendorDeliveryException (API Timeouts)
     */
    @RetryableTopic(
            attempts = "4",
            backoff = @Backoff(delay = 2000, multiplier = 2.0),
            topicSuffixingStrategy = TopicSuffixingStrategy.SUFFIX_WITH_INDEX_VALUE,
            dltTopicSuffix = "-dlq",
            exclude = {
                DecryptionFailureException.class, 
                InvalidPayloadException.class, 
                TemplateNotFoundException.class
            }
    )
    @KafkaListener(
            topics = "fincore.auth.otp.priority",
            groupId = "otp-priority-consumer-group",
            containerFactory = "priorityOtpContainerFactory"
    )
    public void consumeOtpEvent(
            @Payload String message,
            @Header(KafkaHeaders.RECEIVED_TOPIC) String topic,
            @Header(KafkaHeaders.RECEIVED_PARTITION) int partition,
            Acknowledgment acknowledgment) {

        log.debug("Received message on topic {} partition {}", topic, partition);
        String txId = "UNKNOWN";

        try {
            // 1. Parse Outer Wrapper
            Map<String, Object> eventWrapper = mapper.readValue(message, new TypeReference<>() {});
            txId = (String) eventWrapper.get("txId");
            String environment = (String) eventWrapper.get("environment");
            String templateId = (String) eventWrapper.get("templateId");
            List<String> channels = (List<String>) eventWrapper.get("channels");
            Map<String, String> recipients = (Map<String, String>) eventWrapper.get("recipient");
            String encryptedPayload = (String) eventWrapper.get("payload");

            if (txId == null || encryptedPayload == null) throw new InvalidPayloadException("Missing txId or encrypted payload");

            // 2. ZERO-TRUST DECRYPTION
            String decryptedJson;
            try {
                decryptedJson = aesUtil.decrypt(encryptedPayload, internalAesKey);
            } catch (Exception e) {
                log.error("SECURITY ALERT: Decryption failed for txId={}. Possible tampering or key mismatch.", txId);
                throw new DecryptionFailureException("AES Decryption Failed", e);
            }

            Map<String, Object> templateData = mapper.readValue(decryptedJson, new TypeReference<>() {});
            
            // Track partial failures to trigger Spring Kafka Retry
            boolean requiresRetry = false; 

            // 3. CHANNEL ROUTING & IDEMPOTENCY
            for (String channel : channels) {
                // Idempotency Key: Prevents duplicate SMS if Email fails and triggers a retry
                String idempotencyKey = "COMM_IDEMP:" + txId + ":" + channel;
                
                Boolean alreadyProcessed = redisTemplate.opsForValue().setIfAbsent(idempotencyKey, "PROCESSED", Duration.ofMinutes(15));
                if (Boolean.FALSE.equals(alreadyProcessed)) {
                    log.info("Idempotency hit: Already processed {} for txId={}. Skipping.", channel, txId);
                    continue; 
                }

                try {
                    // Dispatch based on channel
                    if ("SMS".equalsIgnoreCase(channel)) {
                        processSms(environment, templateId, recipients.get("mobile"), templateData);
                    } else if ("EMAIL".equalsIgnoreCase(channel)) {
                        processEmail(environment, templateId, recipients.get("email"), templateData);
                    }
                } catch (Exception e) {
                    // If a channel fails, we must remove the idempotency key so it can be retried
                    redisTemplate.delete(idempotencyKey);
                    log.error("Vendor dispatch failed for txId={} channel={}. Exception: {}", txId, channel, e.getMessage());
                    requiresRetry = true;
                }
            }

            // 4. RESOLUTION
            if (requiresRetry) {
                // By throwing this, Spring Kafka routes the message to the Retry Topic
                throw new VendorDeliveryException("One or more channels failed to deliver.", null);
            }

            // ONLY acknowledge if all channels succeeded or were skipped idempotently.
            acknowledgment.acknowledge();
            log.info("Successfully processed Tier-0 OTP Event for txId={}", txId);

        } catch (DecryptionFailureException | InvalidPayloadException | TemplateNotFoundException e) {
            // Deterministic errors: Acknowledge the original message immediately, 
            // the @RetryableTopic will automatically route this payload to the DLT (Dead Letter Topic).
            log.error("Fatal deterministic error processing txId={}. Routing to DLQ. Reason: {}", txId, e.getMessage());
            throw e; 
        } catch (Exception e) {
            // Broad catch for unexpected Jackson parsing errors
            log.error("Unexpected error processing Kafka message: {}", e.getMessage(), e);
            throw new InvalidPayloadException("Unexpected message parsing error");
        }
    }

    // --- Private Processors ---

    private void processSms(String env, String templateId, String mobile, Map<String, Object> data) {
        if (mobile == null || mobile.isBlank()) return;
        
        // 1. Fetch from Oracle / L1 Cache
        String compiledText = templateService.compileTemplate(templateId, "SMS", "EN", data);
        
        // 2. Hand off to Junior's Vendor Service
        smsService.sendSms(mobile, compiledText);
    }

    private void processEmail(String env, String templateId, String email, Map<String, Object> data) {
        if (email == null || email.isBlank()) return;
        
        // 1. Fetch from Oracle / L1 Cache
        String compiledHtml = templateService.compileTemplate(templateId, "EMAIL", "EN", data);
        String subject = templateService.getTemplateSubject(templateId, "EMAIL", "EN");
        
        // 2. Hand off to Junior's Vendor Service
        emailService.sendEmail(email, subject, compiledHtml);
    }
}

