package com.fincore.gateway.Service;

import com.fasterxml.jackson.databind.ObjectMapper;
import com.fincore.commonutilities.util.AesEncryptionUtil;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.beans.factory.annotation.Value;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.stereotype.Service;
import reactor.core.publisher.Mono;

import java.time.Instant;
import java.util.Map;
import java.util.UUID;

@Slf4j
@Service
@RequiredArgsConstructor
public class OtpKafkaProducer {

    private final KafkaTemplate<String, String> kafkaTemplate;
    private final ObjectMapper mapper;
    private final AesEncryptionUtil aesUtil;

    // A valid 256-bit AES key mapped here as default for local testing so your code won't break.
    // Replace in application.properties via: security.internal.kafka-aes-key=YOUR_KEY
    @Value("${security.internal.kafka-aes-key:u1L8a/eW4D/k4oQ5M6w9kO+Xy/o0E5eA/Zz1L8a/eW4=}")
    private String internalAesKey;

    public Mono<Void> publishOtpEvent(String txId, String mobile, String email, String plainOtp, String userName) {
        return Mono.fromCallable(() -> {
            
            /*
             * ====================================================================
             * ZERO-TRUST KAFKA PAYLOAD ARCHITECTURE (Strict Alignment)
             * ====================================================================
             */

            // 1. Build the sensitive inner payload
            Map<String, Object> innerPayload = Map.of(
                "otp", plainOtp,
                "expirySeconds", 300,
                "userName", userName != null ? userName : "User"
            );
            String innerJson = mapper.writeValueAsString(innerPayload);

            // 2. Encrypt the inner payload (Zero-Trust on Broker)
            String encryptedPayload = aesUtil.encrypt(innerJson, internalAesKey);

            // 3. Build the outer routable event
            Map<String, Object> event = Map.of(
                "eventId", "evt-" + UUID.randomUUID().toString(),
                "txId", txId,
                "eventType", "LOGIN_OTP",
                "channel", new String[]{"SMS", "EMAIL"},
                "priority", "CRITICAL",
                "recipient", Map.of(
                        "mobile", mobile != null ? mobile : "", 
                        "email", email != null ? email : ""
                ),
                "payload", encryptedPayload, // The AES encrypted blob
                "createdAt", Instant.now().toString()
            );

            return mapper.writeValueAsString(event);
            
        }).flatMap(jsonString -> {
            // Wraps standard KafkaTemplate into a non-blocking Mono
            return Mono.fromFuture(
                kafkaTemplate.send("fincore.auth.otp.priority", txId, jsonString)
            );
        }).doOnSuccess(result -> log.info("Encrypted OTP event published to Kafka for txId={}", txId))
          .doOnError(e -> log.error("CRITICAL: Kafka publish failed for txId={}", txId, e))
          .then();
    }
}


