CREATE TABLE COMM_TEMPLATE_MASTER (
    -- Composite Primary Key
    TEMPLATE_CODE        VARCHAR2(100) NOT NULL,  -- e.g., 'AUTH_LOGIN_OTP_V1', 'EOD_REPORT'
    CHANNEL              VARCHAR2(20)  NOT NULL,  -- e.g., 'SMS', 'EMAIL', 'WHATSAPP'
    LANGUAGE_CODE        VARCHAR2(5)   DEFAULT 'EN' NOT NULL, -- e.g., 'EN', 'HI'
    
    -- Content
    SUBJECT              VARCHAR2(255),           -- Nullable (SMS doesn't need this)
    BODY_CONTENT         CLOB          NOT NULL,  -- CLOB for large HTML FreeMarker/Mustache payloads
    
    -- Audit & State
    IS_ACTIVE            CHAR(1)       DEFAULT 'Y' NOT NULL,
    CREATED_BY           VARCHAR2(50)  DEFAULT 'SYSTEM' NOT NULL,
    CREATED_AT           TIMESTAMP(6)  DEFAULT SYSTIMESTAMP NOT NULL,
    UPDATED_BY           VARCHAR2(50),
    UPDATED_AT           TIMESTAMP(6),

    CONSTRAINT PK_COMM_TEMPLATE PRIMARY KEY (TEMPLATE_CODE, CHANNEL, LANGUAGE_CODE)
);

-- Index to quickly find only active templates (useful for pre-warming caches on startup)
CREATE INDEX IDX_COMM_TMPL_ACTIVE ON COMM_TEMPLATE_MASTER(IS_ACTIVE);
















