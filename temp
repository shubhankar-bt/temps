package com.fincore.CommunicationService.service;

import com.fincore.CommunicationService.cache.ExternalApiConfigProvider;
import com.fincore.CommunicationService.exception.CommunicationExceptions.VendorDeliveryException;
import com.fincore.CommunicationService.model.FincoreSettings;
import com.fincore.CommunicationService.util.EmailUtil;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Service;
import io.github.resilience4j.circuitbreaker.annotation.CircuitBreaker;
import io.github.resilience4j.retry.annotation.Retry;

import java.util.HashMap;
import java.util.Map;

@Service
@RequiredArgsConstructor
@Slf4j
public class EmailServiceImpl implements EmailService {

    private final ExternalApiConfigProvider configProvider;
    private final TemplateEngineService templateService; // Our L1 Cache Engine

    private static final String FUNCTIONALITY_EMAIL = "EMAIL";
    
    // Constants mapping to EmailUtil
    private static final String URL = "url";
    private static final String API_KEY = "api_key";
    private static final String SENDER_ID = "senderId";
    private static final String TO_EMAIL = "toEmail";
    private static final String EMAIL_BODY = "emailBody";
    private static final String SUBJECT = "subject";

    /**
     * Attempts Primary Email Dispatch.
     * Retries via Resilience4j. If broken, routes to fallbackEmail.
     */
    @Override
    @Retry(name = "primaryEmailRetry", fallbackMethod = "fallbackEmail")
    @CircuitBreaker(name = "primaryEmailCircuit", fallbackMethod = "fallbackEmail")
    public void sendEmail(String environment, String templateId, String toEmail, Map<String, Object> templateData) {
        
        // 1. Fetch Oracle L1 Cached Template & Compile FreeMarker
        String emailBody = templateService.compileTemplate(templateId, "EMAIL", "EN", templateData);
        String subject = templateService.getTemplateSubject(templateId, "EMAIL", "EN");

        // 2. Fetch API Credentials from Fincore Settings
        FincoreSettings config = configProvider.getConfig(FUNCTIONALITY_EMAIL, environment);

        // 3. Prepare Payload for Junior's EmailUtil
        Map<String, Object> emailRequestBody = new HashMap<>();
        emailRequestBody.put(URL, config.getUrl());
        emailRequestBody.put(API_KEY, config.getApiKey());
        emailRequestBody.put(SENDER_ID, config.getSenderId());
        emailRequestBody.put(TO_EMAIL, toEmail);
        emailRequestBody.put(SUBJECT, subject);
        emailRequestBody.put(EMAIL_BODY, emailBody);

        log.info("Dispatching Email via Primary Provider to {}", maskEmail(toEmail));
        
        int responseCode = EmailUtil.sendEmail(emailRequestBody);

        // CRITICAL: Failures throw an exception so Resilience4j/Kafka knows it failed
        if (responseCode < 200 || responseCode >= 300) {
            throw new VendorDeliveryException("Email Provider rejected request. HTTP " + responseCode, null);
        }
    }

    /**
     * THE FALLBACK HOOK.
     * Invoked automatically if Primary Provider is down.
     */
    public void fallbackEmail(String environment, String templateId, String toEmail, Map<String, Object> templateData, Exception ex) {
        log.warn("Primary Email Provider offline. Error: {}. Routing to Fallback Provider.", ex.getMessage());
        
        try {
            // TODO: Implement Secondary Provider (e.g. AWS SES) here later.
            // For now, if Fallback also fails (or isn't implemented), we must throw
            // so Kafka routes this to the Dead Letter Queue (DLQ).
            throw new VendorDeliveryException("Total Email Infrastructure Failure", ex);
            
        } catch (Exception fallbackEx) {
            log.error("CRITICAL: All Email Providers failed for {}.", maskEmail(toEmail));
            throw new VendorDeliveryException("Total Email Infrastructure Failure", fallbackEx);
        }
    }

    private String maskEmail(String email) {
        if (email == null || !email.contains("@")) return email;
        String[] p = email.split("@");
        return (p[0].length() <= 2 ? "**" : p[0].charAt(0) + "***" + p[0].charAt(p[0].length() - 1)) + "@" + p[1];
    }
}

