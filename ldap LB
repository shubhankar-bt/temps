Phase 2: SSL/TLS Optimization (Critical for Speed)
Create a custom SSLSocketFactory that enables TLS 1.3 and SSL Session Resumption:

@Configuration
public class TlsConfig {

    @Bean
    public SSLSocketFactory optimizedSslSocketFactory() throws Exception {
        // Force TLS 1.3 (1-RTT handshake + 0-RTT resumption)
        SSLContext sslContext = SSLContext.getInstance("TLSv1.3");
        
        // Load your .cer certificate (renamed from .txt)
        KeyStore trustStore = KeyStore.getInstance("JKS");
        try (FileInputStream fis = new FileInputStream("path/to/your/certificate.cer")) {
            trustStore.load(fis, "changeit".toCharArray());
        }
        
        TrustManagerFactory tmf = TrustManagerFactory.getInstance(TrustManagerFactory.getDefaultAlgorithm());
        tmf.init(trustStore);
        
        sslContext.init(null, tmf.getTrustManagers(), new SecureRandom());
        
        // Enable session caching (CRITICAL for speed)
        SSLSessionContext sessionContext = sslContext.getClientSessionContext();
        sessionContext.setSessionCacheSize(1000); // Cache 1000 sessions
        sessionContext.setSessionTimeout(300);    // 5-minute timeout
        
        return sslContext.getSocketFactory();
    }
}   






